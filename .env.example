# HomelabVPN Environment Configuration Template
# Copy this file to .env and fill in your values
# Or use the interactive deploy script: ./scripts/deploy.sh

#######################################
# Domain Configuration
#######################################
# Your primary domain (without https://)
DOMAIN=vpn.example.com

# These are auto-derived from DOMAIN
# API_DOMAIN=api.vpn.example.com
# ADMIN_DOMAIN=admin.vpn.example.com

#######################################
# Database Configuration
#######################################
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=homelabvpn
POSTGRES_USER=homelabvpn
POSTGRES_PASSWORD=change-this-secure-password

# Full connection string (auto-generated if using deploy.sh)
# DATABASE_URL=postgres://homelabvpn:password@postgres:5432/homelabvpn?sslmode=disable

#######################################
# Redis Configuration
#######################################
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_URL=redis://redis:6379

#######################################
# Security Secrets
#######################################
# JWT secret for user authentication (minimum 32 characters)
# Generate with: openssl rand -base64 64 | tr -dc 'a-zA-Z0-9' | head -c 64
JWT_SECRET=

# JWT secret for admin authentication (minimum 32 characters)
# Generate with: openssl rand -base64 64 | tr -dc 'a-zA-Z0-9' | head -c 64
ADMIN_JWT_SECRET=

#######################################
# Google OAuth Configuration
#######################################
# Get these from: https://console.cloud.google.com/apis/credentials
# Create an OAuth 2.0 Client ID for a Web application
# Add authorized redirect URI: https://your-domain.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

#######################################
# Stripe Configuration
#######################################
# Get these from: https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_..., pk_test_...) for development
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Webhook secret from: https://dashboard.stripe.com/webhooks
# Create a webhook endpoint: https://api.your-domain.com/api/v1/subscriptions/webhook
# Events to subscribe: checkout.session.completed, customer.subscription.*
STRIPE_WEBHOOK_SECRET=

#######################################
# Admin Configuration
#######################################
# Email for the default admin account
ADMIN_EMAIL=admin@example.com

# Initial admin password (change after first login!)
# If not set, a random password will be generated during deployment
ADMIN_PASSWORD=

#######################################
# Support/Contact
#######################################
SUPPORT_EMAIL=support@example.com

#######################################
# Environment
#######################################
ENVIRONMENT=production
NODE_ENV=production

#######################################
# Docker Registry (for Kubernetes)
#######################################
# If using a private registry, set this
# DOCKER_REGISTRY=your-registry.com
