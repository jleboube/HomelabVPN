# HomelabVPN Backend Environment Variables

# Server
PORT=8080
ENVIRONMENT=development

# Database
DATABASE_URL=postgres://homelabvpn:devpassword@localhost:5432/homelabvpn?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-jwt-secret-change-in-production-min-32-chars

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:3000/api/auth/google/callback
# Production: GOOGLE_REDIRECT_URL=https://vpn.z-q.me/api/auth/google/callback

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# Frontend
FRONTEND_URL=http://localhost:3000
# Production: FRONTEND_URL=https://vpn.z-q.me
