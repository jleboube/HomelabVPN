# HomelabVPN iOS Relay Configuration
# Copy this to .env and update the values

# API Key for syncing with main HomelabVPN API
# Get this from your admin after setting up the relay
RELAY_API_KEY=your-relay-api-key-here

# Main API URL
API_URL=https://api-vpn.z-q.me

# Relay identification
RELAY_NAME=ios-relay-us-east
RELAY_REGION=us-east

# Server hostname (used in client configs)
SERVER_URL=ios-vpn.z-q.me

# Sync interval in seconds (how often to sync peers from API)
SYNC_INTERVAL=60
